# ============================================================
# Noosphere — 统一环境变量模板
# 使用方式：
#   cp .env.example .env
#   然后填入你的 API 密钥（.env 已被 .gitignore 排除，不会入库）
# ============================================================

# DeepSeek API 密钥（必填，三个服务共用）
# 获取方式：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-api-key-here

# 模型选择（可选）
# 可选值: deepseek-v4-pro, deepseek-v4-flash, deepseek-chat, deepseek-reasoner
DEEPSEEK_MODEL=deepseek-v4-pro

# API 地址（可选，通常无需修改）
DEEPSEEK_BASE_URL=https://api.deepseek.com

# CodeLens 待分析的项目目录（可选）
# 会以只读方式挂载到容器内 /workspace
WORKSPACE_DIR=./

# ─── 多 LLM 提供商配置（推荐方式）───
# 复制 workspace/llm_config.example.yaml 为 workspace/llm_config.yaml
# 支持 DeepSeek / OpenAI / Anthropic / Ollama 同时配置
# 详见 workspace/README.md

# ─── AI Gateway（平台内置，非独立服务）───
# 模型配置存储在 workspace/llm_config.yaml
# 管理页面：http://localhost:3000/settings/model
# API 代理：http://localhost:3000/api/gateway/
# Go/Python 后端通过 SDK 直接读取配置并路由 LLM 调用
